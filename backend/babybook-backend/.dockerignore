# 敏感信息（绝对不能打进镜像）
.env
.env.*
!.env.example

# 依赖与构建产物（镜像内会重新 npm ci / build）
node_modules/
dist/
build/

# 版本控制与 CI
.git/
.gitignore
.dockerignore

# 日志与临时文件
*.log
logs/
*.tmp
*.swp

# 测试与覆盖率
coverage/
.nyc_output/
test/

# 文档（无需进镜像）
*.md
!README.md

# 上传的临时文件
uploads/

# 系统与编辑器
.DS_Store
.vscode/
.idea/
