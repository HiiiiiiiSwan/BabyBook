# ==========================================
# BabyBook 后端环境变量配置
# ==========================================

# 应用配置
NODE_ENV=development
PORT=3000

# 数据库配置（PostgreSQL）
# 本地开发使用
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=babybook
DB_SSL=false

# Railway 部署时使用（由 Railway 自动注入）
# DATABASE_URL=postgresql://...

# 豆包 AI 配置（必填）
DOUBAO_API_KEY=your_doubao_api_key_here
DOUBAO_API_URL=https://ark.cn-beijing.volces.com/api/v3/images/generations
DOUBAO_MODEL=doubao-seedream-5-0-260128

# Apple IAP 配置（可选，用于服务端验证）
APPLE_SHARED_SECRET=your_apple_shared_secret_here

# Mock 配置（测试环境使用）
# 设置为 true 时，不调用真实豆包 API，返回 Mock 图片
MOCK_AI_GENERATION=false
MOCK_IMAGE_URL=https://picsum.photos/2048/2048
